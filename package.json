{
  "name": "opencode-git-trailers",
  "version": "0.1.4",
  "description": "Automatically add standardized git trailers to AI-assisted commits for compliance, audit trails, and attribution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@opencode-ai/plugin": "^1.17.9",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lannuttia/opencode-git-trailers.git"
  },
  "author": "Anthony Lannutti <lannuttia@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/lannuttia/opencode-git-trailers#readme",
  "bugs": "https://github.com/lannuttia/opencode-git-trailers/issues",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "opencode-ai",
    "git",
    "git-trailers",
    "commit",
    "commit-message",
    "metadata",
    "ai",
    "ai-assisted",
    "coding-assistant",
    "plugin",
    "automation",
    "developer-tools",
    "compliance",
    "audit-trail",
    "git-hooks",
    "commit-msg",
    "signed-off-by",
    "co-authored-by",
    "llm",
    "ai-transparency"
  ],
  "dependencies": {}
}
